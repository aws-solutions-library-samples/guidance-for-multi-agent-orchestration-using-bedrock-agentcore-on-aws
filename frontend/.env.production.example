# Production Environment Configuration
# This file is auto-generated by the deployment script
# DO NOT commit .env.production to version control

# AWS Region where the Cognito User Pool is deployed
VITE_AWS_REGION=us-east-1

# GraphQL API URL from CustomerSupportAssistantStack output
VITE_GRAPHQL_API_URL=https://xxxxxxxxxx.appsync-api.us-east-1.amazonaws.com/graphql

# Supervisor Agent Runtime ARN from CustomerSupportAssistantStack output
VITE_SUPERVISOR_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/customer_support_supervisor-XXXXX

# User Pool ID from CustomerSupportAssistantStack output
VITE_USER_POOL_ID=us-east-1_XXXXXXXXX

# User Pool Client ID from CustomerSupportAssistantStack output
VITE_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# IMPORTANT: To generate this file automatically, run:
#   cd infrastructure
#   ./deploy-complete-system.sh
#
# Or manually run:
#   cd frontend
#   npm run setup-config -- --region us-east-1
